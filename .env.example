# Required — Claude vision backend for table extraction
ANTHROPIC_API_KEY=

# Required — Postgres for users / api_keys / usage_events / subscriptions
DATABASE_URL=

# Required — Stripe for billing (subscriptions + metered overage)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_HOBBY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_METER_OVERAGE=

# Required — Resend for transactional emails (API key delivery, receipts)
RESEND_API_KEY=
